{
  "manifest_version": 3,
  "name": "MultiLeilao",
  "description": "Scanner operacional multi-fonte para oportunidades em leiloes.",
  "version": "1.0.0",
  "action": {
    "default_title": "MultiLeilao"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
