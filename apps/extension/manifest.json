{
  "manifest_version": 3,
  "name": "LEILAOAUTO",
  "description": "Assistente operacional de oportunidades em leiloes automotivos.",
  "version": "1.0.0",
  "action": {
    "default_title": "LEILAOAUTO"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
