{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=leilaoauto;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "LeilaoAuto.Api",
    "Audience": "LeilaoAuto.Web",
    "SecretKey": "LEILAOAUTO__JWT__THIS_IS_A_LONG_SECRET_KEY_FOR_DEVELOPMENT_2026",
    "ExpiresMinutes": 180
  },
  "AuctionProviders": {
    "Primary": {
      "MockMode": true,
      "BaseUrl": "https://provider.leilaoauto.local",
      "LotsEndpoint": "/api/lots",
      "ApiKey": ""
    }
  },
  "Fipe": {
    "Enabled": true,
    "BaseUrl": "https://brasilapi.com.br",
    "PriceByCodeEndpoint": "/api/fipe/preco/v1/{code}",
    "UseEstimatedFallback": true,
    "ModelCodeMappings": {
      "GOL 1 6 MSI": "005340-6"
    }
  },
  "Billing": {
    "Provider": "Fake",
    "StripeSecretKey": "",
    "StripeWebhookSecret": "",
    "SuccessUrl": "http://localhost:4200/billing?checkout=success",
    "CancelUrl": "http://localhost:4200/billing?checkout=cancel"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://127.0.0.1:4200" ]
  },
  "Http": {
    "UseHttpsRedirection": true
  },
  "AllowedHosts": "*"
}
