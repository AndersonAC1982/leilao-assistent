{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=leilaoauto;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "LeilaoAuto.Api",
    "Audience": "LeilaoAuto.Web",
    "SecretKey": "LEILAOAUTO__JWT__THIS_IS_A_LONG_SECRET_KEY_FOR_DEVELOPMENT_2026",
    "ExpiresMinutes": 180
  },
  "AuctionProviders": {
    "Primary": {
      "MockMode": true,
      "BaseUrl": "https://provider.leilaoauto.local",
      "LotsEndpoint": "/api/lots",
      "ApiKey": ""
    }
  },
  "Fipe": {
    "Enabled": true,
    "BaseUrl": "https://brasilapi.com.br",
    "PriceByCodeEndpoint": "/api/fipe/preco/v1/{code}",
    "UseEstimatedFallback": true,
    "ModelCodeMappings": {
      "GOL 1 6 MSI": "005340-6"
    }
  },
  "Worker": {
    "Enabled": true,
    "SyncIntervalSeconds": 180,
    "ConnectorRetryCount": 3,
    "ConnectorRetryDelaySeconds": 2,
    "RunOnStartup": true
  }
}
